        "# Do not use\n",
        "\n",
        "from sentence_transformers import SentenceTransformer\n",
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "# --- Load SBERT model\n",
        "model = SentenceTransformer('all-MiniLM-L6-v2')\n",
        "\n",
        "# --- Step 1: Define multiple stress anchors\n",
        "anchor_texts = [\n",
        "    # Pressure / overwhelm\n",
        "    \"I feel overwhelmed with too many responsibilities and too much pressure\",\n",
        "\n",
        "    # Anxiety\n",
        "    \"I feel anxious, worried all the time, and cannot relax\",\n",
        "\n",
        "    # Mental exhaustion\n",
        "    \"I feel mentally exhausted, drained, and unable to cope anymore\",\n",
        "\n",
        "    # Hopelessness / failure\n",
        "    \"I feel like I am failing, nothing is working, and I don't know what to do\",\n",
        "\n",
        "    # Emotional distress\n",
        "    \"I feel emotionally heavy, stuck, and unable to handle my situation\"\n",
        "]\n",
        "\n",
        "# Encode all anchors\n",
        "anchor_embeddings = model.encode(anchor_texts)\n",
        "\n",
        "# --- Step 2: Compute stress score per row using MAX similarity\n",
        "def compute_multi_anchor_stress(row_emb, anchor_embs):\n",
        "    sims = cosine_similarity(row_emb.reshape(1, -1), anchor_embs)[0]\n",
        "    max_sim = max(sims)\n",
        "    return int(round(max_sim * 100))  # 0–100 integer\n",
        "\n",
        "# --- Step 3: Apply to all input embeddings\n",
        "df_combined['sbert_stress_score'] = [\n",
        "    compute_multi_anchor_stress(input_embeddings[i], anchor_embeddings)\n",
        "    for i in range(len(df_combined))\n",
        "]\n",
        "\n",
        "# --- Step 4: Save updated file\n",
        "combined_file = '/content/drive/MyDrive/mentalhealth/combined_mentalhealth_data.csv'\n",
        "df_combined.to_csv(combined_file, index=False)\n",
        "\n",
        "print(\"✅ Multi-anchor SBERT stress scores saved.\")\n",
        "\n",
        "# --- Step 5: Quick check\n",
        "print(\"\\nAverage SBERT stress by user_type:\")\n",
        "print(df_combined.groupby(\"user_type\")[\"sbert_stress_score\"].mean())"
